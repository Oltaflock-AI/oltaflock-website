# Copy to .env and fill in. Do NOT commit .env.

# Cal.com link for the "Book a Call" button, e.g. "oltaflock/30min".
# If unset, the button scrolls to the on-page contact form instead.
VITE_CALCOM_LINK=

# Optional: API base URL when the API is not served from the app origin.
VITE_API_URL=

# --- Server-side only (set in your host, e.g. Vercel project env) ---
# Used by /api/send-message. These are NOT exposed to the browser.
RESEND_API_KEY=
# Optional From address (defaults to onboarding@resend.dev)
RESEND_FROM=
